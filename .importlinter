# Architectural fitness function (CLAUDE.md core decision principle).
#
# AI reads / suggests / explains. Deterministic logic decides / scores /
# classifies. A compliance decision must NEVER reach the user directly from
# an AI output. This file turns that principle from a convention into a
# mechanically enforced invariant: the deterministic core may not import the
# AI layer or any LLM SDK, and `lint-imports` FAILS the build if it does.
#
# Enforced through the test suite by tests/test_architecture.py, which runs
# `lint-imports` and asserts a clean exit — so a violation breaks `pytest`,
# the same gate every other invariant goes through.

[importlinter]
root_package = pdpl
# Required so the forbidden contract can name third-party LLM SDKs (anthropic,
# openai, ...) that live outside the `pdpl` package.
include_external_packages = True

# Contract 1 (existing): the deterministic core may not import the AI layer.
[importlinter:contract:deterministic-core-no-ai]
name = Deterministic core must not import the AI layer or any LLM SDK
type = forbidden
# The deterministic core: the modules that decide, score, and classify.
# These produce or aggregate compliance verdicts and must stay provably free
# of AI in their import graph (direct OR transitive).
source_modules =
    pdpl.services.decision
    pdpl.services.checks
    pdpl.services.scoring
    pdpl.services.alerts
# Reserved internal AI namespace (Phase 4 lives here, forbidden from day one)
# plus every LLM SDK we might reach for. grimp analyses imports statically, so
# these are caught even when the SDK is not installed.
forbidden_modules =
    pdpl.ai
    anthropic
    openai
    google
    vertexai
    cohere
    litellm
    langchain

# Contract 2 (new, ADR-0009 §7): the AI layer may not import the decision
# core. The one-directional fence above left a back door — the AI reads
# deterministic outputs AS DATA (a GapContext handed to it), and must not be
# able to import the decision machinery and thereby recompute or feed back
# into a verdict. This closes it.
[importlinter:contract:ai-no-decision-core]
name = AI layer must not import the deterministic decision core
type = forbidden
source_modules =
    pdpl.ai
forbidden_modules =
    pdpl.services.decision
    pdpl.services.checks
    pdpl.services.scoring

# Contract 3 (new, ADR-0009 §7): the verifier is the TRUSTED guard and must be
# fully independent of the untrusted producer. A guard that imports the thing
# it guards is a category error — enforce its independence, do not assume it.
[importlinter:contract:verification-no-ai]
name = Verification gate must not import the AI layer or any LLM SDK
type = forbidden
source_modules =
    pdpl.verification
forbidden_modules =
    pdpl.ai
    anthropic
    openai
    google
    vertexai
    cohere
    litellm
    langchain

# Contract 4 (ADR-0009 §7 + C3a): the verifier must also be independent of the
# decision core AND the seed catalogue. It consumes only the minimal control
# facts passed as plain arguments, never the decision machinery and never the
# catalogue's data — so it stays hermetic and cannot drift toward re-deciding
# (or re-grounding) instead of verifying.
[importlinter:contract:verification-no-decision-core]
name = Verification gate must not import the decision core or the catalogue
type = forbidden
source_modules =
    pdpl.verification
forbidden_modules =
    pdpl.services.decision
    pdpl.services.checks
    pdpl.services.scoring
    pdpl.catalog

# Contract 5 (new, ADR-0010): the eval harness is TOOLING — it measures the
# feature, it is never part of it. Nothing in production may import it, so the
# eval cannot accidentally become a runtime dependency (and, e.g., drag pyyaml
# or the golden-set file into the serving path). The eval freely imports
# pdpl.ai (the stub) and pdpl.verification (the shared gate); only the reverse
# is forbidden.
[importlinter:contract:production-no-eval]
name = Production code must not import the eval harness (eval is tooling)
type = forbidden
source_modules =
    pdpl.ai
    pdpl.api
    pdpl.catalog
    pdpl.db
    pdpl.explanations
    pdpl.notifications
    pdpl.observability
    pdpl.services
    pdpl.verification
    pdpl.workers
forbidden_modules =
    pdpl.eval

# Contract 6 (C3a, ADR-0009 §2): the seed catalogue is a PURE LEAF. It holds
# static, tenant-agnostic control/question metadata and the readable-text join
# the explainer is grounded on; it must depend on nothing inside the product.
# Keeping it a leaf is what lets BOTH the eval tooling and the future C4 app
# layer import it without pulling in the decision core, the AI layer, or the
# verifier — and guarantees the catalogue can never reach back into a verdict.
[importlinter:contract:catalog-is-a-leaf]
name = Seed catalogue must be a pure leaf (no AI, decision core, or verifier)
type = forbidden
source_modules =
    pdpl.catalog
forbidden_modules =
    pdpl.ai
    pdpl.services
    pdpl.verification
    pdpl.explanations

# Contract 7 (C4a, ADR-0011 §7): the runtime orchestration may not import the
# decision core. `pdpl.explanations` receives the engine's `ControlDecision`
# AS DATA via dependency injection (the C4b endpoint composes the decider with
# `explain_gap` OUTSIDE this layer). Forbidding the import is a free lock of a
# real boundary: the explanation layer reads a deterministic verdict and can
# never reach back to recompute or feed into one. It freely imports pdpl.ai
# (the producer), pdpl.verification (the gate), pdpl.catalog (the join), and
# pdpl.db (the cache) — only the decision core is closed.
[importlinter:contract:explanations-no-decision-core]
name = Runtime orchestration must not import the deterministic decision core
type = forbidden
source_modules =
    pdpl.explanations
forbidden_modules =
    pdpl.services.decision
    pdpl.services.checks
    pdpl.services.scoring
