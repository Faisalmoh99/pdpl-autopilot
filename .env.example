# Supabase Postgres connection URLs.
#
# DATABASE_URL_DIRECT: the *direct* (non-pooled) connection on port 5432.
#   Used by Alembic to run migrations. The Supabase pooler (Supavisor)
#   cannot execute DDL, so migrations MUST use the direct URL.
#   Format: postgresql+psycopg2://postgres:<password>@<project>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL_DIRECT=postgresql+psycopg2://postgres:CHANGE_ME@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# DATABASE_URL: the pooled connection (Supavisor, port 6543) used by the
#   FastAPI runtime via asyncpg. Not used by Alembic.
#   Format: postgresql+asyncpg://postgres.<project>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT:CHANGE_ME@aws-0-REGION.pooler.supabase.com:6543/postgres
