# =====================================================================
# PDPL Autopilot — environment template.
# Copy to .env and fill in the real values. .env is git-ignored.
# Per ADR-0004, every var listed here is *required* — the app and the
# migration fail fast at startup if any of them is missing.
# =====================================================================

# ---- Alembic (migration role: the Supabase `postgres` superuser) ----
# DATABASE_URL_DIRECT: the *direct* (non-pooled) connection on port 5432.
#   Used by Alembic ONLY. The Supabase pooler (Supavisor) cannot run DDL,
#   so migrations MUST use the direct URL.
#   Format: postgresql+psycopg2://postgres:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL_DIRECT=postgresql+psycopg2://postgres:CHANGE_ME@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# ---- Application runtime (application role: `pdpl_app`) ----
# APP_DATABASE_URL: the FastAPI runtime connection, as `pdpl_app` (NOT
#   postgres). Per ADR-0003 + ADR-0004 §5, this is what enforces
#   audit-log immutability on the application path.
#
#   PREFERRED — Supavisor pooled URL (port 6543), transaction mode:
#     postgresql+asyncpg://pdpl_app.<project>:<pdpl_app_pwd>@<region>.pooler.supabase.com:6543/postgres
#   ACCEPTABLE FALLBACK — direct URL (port 5432) still as pdpl_app, if
#     the pooler refuses the custom role:
#     postgresql+asyncpg://pdpl_app:<pdpl_app_pwd>@db.<project>.supabase.co:5432/postgres
#   FORBIDDEN — anything that authenticates as `postgres` or another
#     owner role. That silently nullifies ADR-0003.
APP_DATABASE_URL=postgresql+asyncpg://pdpl_app.YOUR_PROJECT:CHANGE_ME@aws-0-REGION.pooler.supabase.com:6543/postgres

# ---- Migration-time secret ----
# PDPL_APP_PASSWORD: the password applied to the `pdpl_app` role by
#   migration 0002 (ALTER ROLE pdpl_app WITH LOGIN PASSWORD ...).
#   Required ONLY when running `alembic upgrade` for migration 0002.
#   The FastAPI runtime does NOT read this var — the runtime gets the
#   same password embedded in APP_DATABASE_URL above. Keep them in sync.
PDPL_APP_PASSWORD=CHANGE_ME

# =====================================================================
# Alerting + outbox worker (ADR-0008). UNLIKE the vars above, these are
# OPTIONAL for the API and migrations — the app boots without them. They
# are required ONLY to run the outbox delivery worker
# (`python -m pdpl.workers.outbox`), which fails fast at startup if the
# worker DB URL or the webhook URL/secret are missing.
# =====================================================================

# ---- Webhook Notifier (the first concrete Notifier) ----
# ALERT_WEBHOOK_URL: where signed alert webhooks are POSTed.
# ALERT_WEBHOOK_SECRET: the HMAC-SHA256 signing secret (SecretStr; never
#   logged — only a short fingerprint is). Keep it out of source control.
# ALERT_WEBHOOK_TIMEOUT_SECONDS: a single overall wall-clock send deadline
#   (NOT per connect/read). This is also the worker's row-lock-hold ceiling.
ALERT_WEBHOOK_URL=https://example.com/pdpl/alerts
ALERT_WEBHOOK_SECRET=CHANGE_ME
ALERT_WEBHOOK_TIMEOUT_SECONDS=5

# ---- Outbox worker connection + retry policy ----
# WORKER_DATABASE_URL: the worker's OWN connection, as `pdpl_app`, on a
#   session-level / DIRECT connection (port 5432). NOT the transaction
#   pooler (FOR UPDATE + a held transaction do not fit the transaction
#   pooler), and NEVER an owner role.
#   Format: postgresql+asyncpg://pdpl_app:<pdpl_app_pwd>@db.<project>.supabase.co:5432/postgres
WORKER_DATABASE_URL=postgresql+asyncpg://pdpl_app:CHANGE_ME@db.YOUR_PROJECT.supabase.co:5432/postgres
# Full-jitter exponential backoff: next_attempt_at = now() +
#   random(0, min(base * 2^(attempts-1), cap)); dead-letter after max attempts.
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_BACKOFF_BASE_SECONDS=60
OUTBOX_BACKOFF_CAP_SECONDS=3600
OUTBOX_POLL_INTERVAL_SECONDS=5
